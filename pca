    "class custom_PCA:\n",
    "    def __init__(self,n_components):\n",
    "        self.n_components=n_components\n",
    "        self.components=None\n",
    "\n",
    "    def fit_transform(self, X):\n",
    "        cov_matrix=np.cov(X, rowvar=False)\n",
    "        en_values, en_vector=np.linalg.eig(cov_matrix)\n",
    "\n",
    "        #sort\n",
    "        sort_idx= np.argsort(en_values)[::-1]\n",
    "        en_values=en_values[sort_idx]\n",
    "        en_vector=en_vector[:, sort_idx]  # takes all rows  but reorder the columns using sorted_idx\n",
    "\n",
    "        #select top compoents\n",
    "        self.components=en_vector[:,:self.n_components]\n",
    "\n",
    "        #transform the data\n",
    "        X_transformed=X@self.components\n",
    "        return X_transformed"
   ]

plit(X, y)\n","model_train_test(X_train, y_train)"]},{"cell_type":"markdown","id":"063d97d3","metadata":{"papermill":{"duration":0.006096,"end_time":"2026-03-31T05:48:54.955389+00:00","exception":false,"start_time":"2026-03-31T05:48:54.949293+00:00","status":"completed"},"tags":[]},"source":["``` Now we have coefficient, we will try to find the intercept```"]},{"cell_type":"markdown","id":"9f85cd45","metadata":{"papermill":{"duration":0.006078,"end_time":"2026-03-31T05:48:54.968733+00:00","exception":false,"start_time":"2026-03-31T05:48:54.962655+00:00","status":"completed"},"tags":[]},"source":["\\begin{equation}\n","y = \\beta_0 + \\beta_1 x_1 + \\beta_2 x_2 + \\cdots + \\beta_n x_n\n","\\end{equation}"]},{"cell_type":"markdown","id":"7290c98c","metadata":{"papermill":{"duration":0.006081,"end_time":"2026-03-31T05:48:54.980789+00:00","exception":false,"start_time":"2026-03-31T05:48:54.974708+00:00","status":"completed"},"tags":[]},"source":["# Finding the intercpt when betas given"]},{"cell_type":"markdown","id":"0fecbf34","metadata":{"papermill":{"duration":0.006375,"end_time":"2026-03-31T05:48:54.99329+00:00","exception":false,"start_time":"2026-03-31T05:48:54.986915+00:00","status":"completed"},"tags":[]},"source":["\n","\n","\\\n","\\begin{align*}\n","\\frac{\\partial L}{\\partial \\text{intercept}} \n","&= \\frac{\\partial}{\\partial \\text{intercept}} \\left( \\frac{1}{m} \\sum_{i=1}^m (y_i - \\hat{y}_i)^2 \\right) \\\\\n","&= \\frac{1}{m} \\sum_{i=1}^m 2 (y_i - \\hat{y}_i) \\frac{\\partial (y_i - \\hat{y}_i)}{\\partial \\text{intercept}} \\\\\n","&= \\frac{1}{m} \\sum_{i=1}^m 2 (y_i - \\hat{y}_i) \\cdot (-1) \\\\\n","&= -\\frac{2}{m} \\sum_{i=1}^m (y_i - \\hat{y}_i)\n","\\end{align*}\n","\\\n","\n","\n","\n"]},{"cell_type":"code","execution_count":10,"id":"2cc9b883","metadata":{"execution":{"iopub.execute_input":"2026-03-31T05:48:55.008455Z","iopub.status.busy":"2026-03-31T05:48:55.007958Z","iopub.status.idle":"2026-03-31T05:48:55.015431Z","shell.execute_reply":"2026-03-31T05:48:55.014455Z"},"papermill":{"duration":0.017292,"end_time":"2026-03-31T05:48:55.017301+00:00","exception":false,"start_time":"2026-03-31T05:48:55.000009+00:00","status":"completed"},"tags":[]},"outputs":[],"source":["class GD:\n","    def __init__(self, x1,x2,x3,x4, lr=0.01):\n","        self.x1=x1\n","        self.x2=x2\n","        self.x3=x3\n","        self.x4=x4\n","        self.lr=lr\n","        self.intercept = 0\n","\n","\n","    def fit(self, X_train, y_train, epoch=1000):\n","        m=len(X_train)\n","        intercept=np.random.uniform(-1000,1000)\n","        \n","        for i in range(epoch):\n","            y_pred= self.intercept + self.x1*X_train.iloc[:,0] + self.x2*X_train.iloc[:,1] + self.x3*X_train.iloc[:,2] + self.x4*X_train.iloc[:,3]\n","\n","            grad=-(2/m)*np.sum(y_train-y_pred)\n","            \n","            self.intercept=self.intercept -self.lr*grad\n","            \n","        return self.intercept"]},{"cell_type":"code","execution_count":11,"id":"bc1bb36a","metadata":{"execution":{"iopub.execute_input":"2026-03-31T05:48:55.03205Z","iopub.status.busy":"2026-03-31T05:48:55.031322Z","iopub.status.idle":"2026-03-31T05:48:56.090711Z","shell.execute_reply":"2026-03-31T05:48:56.089638Z"},"papermill":{"duration":1.069151,"end_time":"2026-03-31T05:48:56.09284+00:00","exception":false,"start_time":"2026-03-31T05:48:55.023689+00:00","status":"completed"},"tags":[]},"outputs":[{"data":{"text/plain":["np.float64(-33.60206754733134)"]},"execution_count":11,"metadata":{},"output_type":"execute_result"}],"source":["x1=2.85289351 \n","x2=1.01703572 \n","x3=0.47331832 \n","x4=0.19172629\n","gd=GD(x1,x2,x3,x4)\n","gd.fit(X_train, y_train)\n","#incpt"]},{"cell_type":"markdown","id":"b1cb6cd8","metadata":{"papermill":{"duration":0.006641,"end_time":"2026-03-31T05:48:56.105857+00:00","exception":false,"start_time":"2026-03-31T05:48:56.099216+00:00","status":"completed"},"tags":[]},"source":["``` We get the same intercept as earlie
equation}\n","\\frac{\\partial L}{\\partial \\mathbf{w}} = -\\frac{2}{B} \\mathbf{X}^\\top (\\mathbf{y} - \\hat{\\mathbf{y}})\n","\\end{equation}\n","\n","## Update Rules\n","\n","### Intercept Update:\n","\\begin{equation}\n","b := b - \\eta \\cdot \\frac{\\partial L}{\\partial b}\n","\\end{equation}\n","\n","\\begin{equation}\n","b := b - \\left(-\\frac{2}{B} \\eta \\sum (y - \\hat{y}) \\right)\n","\\end{equation}\n","\n","### Coefficient Update:\n","\\begin{equation}\n","\\mathbf{w} := \\mathbf{w} - \\eta \\cdot \\frac{\\partial L}{\\partial \\mathbf{w}}\n","\\end{equation}\n","\n","\\begin{equation}\n","\\mathbf{w} := \\mathbf{w} - \\left( \\frac{2}{B} \\eta \\mathbf{X}^\\top (y - \\hat{y}) \\right)\n","\\end{equation}\n","\n","### Vector Form\n","\n","\\begin{equation}\n","\\mathbf{e} = \\mathbf{y}_{batch} - \\hat{\\mathbf{y}}_{batch}\n","\\end{equation}\n","\n","\\begin{equation}\n","b := b - \\left(-\\frac{2}{B} \\eta \\sum \\mathbf{e} \\right)\n","\\end{equation}\n","\n","\\begin{equation}\n","\\mathbf{w} := \\mathbf{w} - \\left( \\frac{2}{B} \\eta \\mathbf{X}_{batch}^\\top \\mathbf{e} \\right)\n","\\end{equation}"]},{"cell_type":"markdown","id":"8948220e","metadata":{"papermill":{"duration":0.011674,"end_time":"2026-04-02T01:59:37.867482+00:00","exception":false,"start_time":"2026-04-02T01:59:37.855808+00:00","status":"completed"},"tags":[]},"source":["## Dataframe"]},{"cell_type":"code","execution_count":40,"id":"3e8f19ff","metadata":{"execution":{"iopub.execute_input":"2026-04-02T01:59:37.897164Z","iopub.status.busy":"2026-04-02T01:59:37.896236Z","iopub.status.idle":"2026-04-02T01:59:37.928852Z","shell.execute_reply":"2026-04-02T01:59:37.927562Z"},"papermill":{"duration":0.050762,"end_time":"2026-04-02T01:59:37.930945+00:00","exception":false,"start_time":"2026-04-02T01:59:37.880183+00:00","status":"completed"},"tags":[]},"outputs":[{"data":{"text/html":["<div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: mi
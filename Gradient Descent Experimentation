tadata":{"papermill":{"duration":0.003775,"end_time":"2026-03-26T13:44:37.224068+00:00","exception":false,"start_time":"2026-03-26T13:44:37.220293+00:00","status":"completed"},"tags":[]},"source":["\\begin{equation}\n","y = \\beta_0 + \\beta_1 x_1 + \\beta_2 x_2 + \\cdots + \\beta_n x_n\n","\\end{equation}"]},{"cell_type":"markdown","id":"8db485f7","metadata":{"papermill":{"duration":0.003778,"end_time":"2026-03-26T13:44:37.231839+00:00","exception":false,"start_time":"2026-03-26T13:44:37.228061+00:00","status":"completed"},"tags":[]},"source":["# Finding the intercpt when betas given"]},{"cell_type":"markdown","id":"34fe1b95","metadata":{"papermill":{"duration":0.003719,"end_time":"2026-03-26T13:44:37.239372+00:00","exception":false,"start_time":"2026-03-26T13:44:37.235653+00:00","status":"completed"},"tags":[]},"source":["\n","\n","\\\n","\\begin{align*}\n","\\frac{\\partial L}{\\partial \\text{intercept}} \n","&= \\frac{\\partial}{\\partial \\text{intercept}} \\left( \\frac{1}{m} \\sum_{i=1}^m (y_i - \\hat{y}_i)^2 \\right) \\\\\n","&= \\frac{1}{m} \\sum_{i=1}^m 2 (y_i - \\hat{y}_i) \\frac{\\partial (y_i - \\hat{y}_i)}{\\partial \\text{intercept}} \\\\\n","&= \\frac{1}{m} \\sum_{i=1}^m 2 (y_i - \\hat{y}_i) \\cdot (-1) \\\\\n","&= -\\frac{2}{m} \\sum_{i=1}^m (y_i - \\hat{y}_i)\n","\\end{align*}\n","\\\n","\n","\n","\n"]},{"cell_type":"code","execution_count":10,"id":"cda1bb00","metadata":{"execution":{"iopub.execute_input":"2026-03-26T13:44:37.248633Z","iopub.status.busy":"2026-03-26T13:44:37.248287Z","iopub.status.idle":"2026-03-26T13:44:37.256603Z","shell.execute_reply":"2026-03-26T13:44:37.255561Z"},"papermill":{"duration":0.015443,"end_time":"2026-03-26T13:44:37.258681+00:00","exception":false,"start_time":"2026-03-26T13:44:37.243238+00:00","status":"completed"},"tags":[]},"outputs":[],"source":["class GD:\n","    def __init__(self, x1,x2,x3,x4, lr=0.01):\n","        self.x1=x1\n","        self.x2=x2\n","        self.x3=x3\n","        self.x4=x4\n","        self.lr=lr\n","        self.intercept = 0\n","\n","\n","    def fit(self, X_train, y_train, epoch=1000):\n","        m=len(X_train)\n","        intercept=np.random.uniform(-1000,1000)\n","        \n","        for i in range(epoch):\n","            y_pred= self.intercept + self.x1*X_train.iloc[:,0] + self.x2*X_train.iloc[:,1] + self.x3*X_train.iloc[:,2] + self.x4*X_train.iloc[:,3]\n","\n","            grad=-(2/m)*np.sum(y_train-y_pred)\n","            \n","            self.intercept=self.intercept -self.lr*grad\n","            \n","        return self.intercept"]},{"cell_type":"code","execution_count":11,"id":"31dbae82","metadata":{"execution":{"iopub.execute_input":"2026-03-26T13:44:37.268383Z","iopub.status.busy":"2026-03-26T13:44:37.268058Z","iopub.status.idle":"2026-03-26T13:44:38.283828Z","shell.execute_reply":"2026-03-26T13:44:38.282408Z"},"papermill":{"duration":1.023436,"end_time":"2026-03-26T13:44:38.28629+00:00","exception":false,"start_time":"2026-03-26T13:44:37.262854+00:00","status":"completed"},"tags":[]},"outputs":[{"data":{"text/plain":["np.float64(-33.60206754733134)"]},"execution_count":11,"metadata":{},"output_type":"execute_result"}],"source":["x1=2.85289351 \n","x2=1.01703572 \n","x3=0.47331832 \n","x4=0.19172629\n","gd=GD(x1,x2,x3,x4)\n","gd.fit(X_train, y_train)\n","#incpt"]},{"cell_type":"markdown","id":"0b6cc806","metadata":{"papermill":{"duration":0.004017,"end_time":"2026-03-26T13:44:38.294521+00:00","exception":false,"start_time":"2026-03-26T13:44:38.290504+00:00","status":"completed"},"tags":[]},"source":["``` We get the same intercept as earlier which is -33.60206```"]},{"cell_type":"code","execution_count":null,"id":"67916428","metadata":{"papermill":{"duration":0.004103,"end_time":"2026-03-26T13:44:38.302788+00:00","exception":false,"start_time":"2026-03-26T13:44:38.298685+00:00","status":"completed"},"tags":[]},"outputs":[],"source":[]}],"metadata":{"kaggle":{"accelerator":"none","dataSources":[{"databundleVersionId":6130086,"datasetId":
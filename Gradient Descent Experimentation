:{"duration":0.009401,"end_time":"2026-04-02T01:59:34.144314+00:00","exception":false,"start_time":"2026-04-02T01:59:34.134913+00:00","status":"completed"},"tags":[]},"source":["\n","\n","\\\n","\\begin{align*}\n","\\frac{\\partial L}{\\partial \\text{intercept}} \n","&= \\frac{\\partial}{\\partial \\text{intercept}} \\left( \\frac{1}{m} \\sum_{i=1}^m (y_i - \\hat{y}_i)^2 \\right) \\\\\n","&= \\frac{1}{m} \\sum_{i=1}^m 2 (y_i - \\hat{y}_i) \\frac{\\partial (y_i - \\hat{y}_i)}{\\partial \\text{intercept}} \\\\\n","&= \\frac{1}{m} \\sum_{i=1}^m 2 (y_i - \\hat{y}_i) \\cdot (-1) \\\\\n","&= -\\frac{2}{m} \\sum_{i=1}^m (y_i - \\hat{y}_i)\n","\\end{align*}\n","\\\n","\n","\n","\n"]},{"cell_type":"code","execution_count":10,"id":"c360638a","metadata":{"execution":{"iopub.execute_input":"2026-04-02T01:59:34.165379Z","iopub.status.busy":"2026-04-02T01:59:34.164616Z","iopub.status.idle":"2026-04-02T01:59:34.171549Z","shell.execute_reply":"2026-04-02T01:59:34.170697Z"},"papermill":{"duration":0.019731,"end_time":"2026-04-02T01:59:34.173514+00:00","exception":false,"start_time":"2026-04-02T01:59:34.153783+00:00","status":"completed"},"tags":[]},"outputs":[],"source":["class GD:\n","    def __init__(self, x1,x2,x3,x4, lr=0.01):\n","        self.x1=x1\n","        self.x2=x2\n","        self.x3=x3\n","        self.x4=x4\n","        self.lr=lr\n","        self.intercept = 0\n","\n","\n","    def fit(self, X_train, y_train, epoch=1000):\n","        m=len(X_train)\n","        intercept=np.random.uniform(-1000,1000)\n","        \n","        for i in range(epoch):\n","            y_pred= self.intercept + self.x1*X_train.iloc[:,0] + self.x2*X_train.iloc[:,1] + self.x3*X_train.iloc[:,2] + self.x4*X_train.iloc[:,3]\n","\n","            grad=-(2/m)*np.sum(y_train-y_pred)\n","            \n","            self.intercept=self.intercept -self.lr*grad\n","            \n","        return self.intercept"]},{"cell_type":"code","execution_count":11,"id":"88198665","metadata":{"execution":{"iopub.ex